# ── earnd environment ───────────────────────────────────────────────
# Copy to apps/web/.env.local for local dev. NEVER commit real values.

# Neon Postgres (transactional ledger). Use a Neon dev branch for local work.
DATABASE_URL="postgresql://user:password@host/earnd?sslmode=require"

# Stripe — TEST MODE keys for development.
# Prefer a RESTRICTED key (rk_) over the secret key (sk_) in production.
STRIPE_SECRET_KEY="rk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From `stripe listen` — the signing secret for webhook verification.
STRIPE_WEBHOOK_SECRET="whsec_..."

# Server-side HMAC key for signing impression + click tokens. REQUIRED: 32+ chars,
# and must not start with "change-me" (the app rejects the placeholder at startup).
# Generate: openssl rand -base64 48
EARND_TOKEN_SIGNING_KEY="REPLACE_ME__openssl_rand_base64_48"

# Public base URL of the web app (used in Checkout redirect + OSC 8 links).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# The host the banner client TCP-probes for its offline check + API base.
EARND_API_BASE="http://localhost:3000"

# Bearer token gating the moderation queue (/admin/moderation) and the payout
# runner (/api/payouts/run). 16+ chars, not the "change-me" placeholder. UNSET =>
# both fail closed: no creative can be approved and no payout can run.
# Generate: openssl rand -hex 24
EARND_ADMIN_TOKEN="REPLACE_ME__openssl_rand_hex_24"
